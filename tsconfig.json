{

  "compilerOptions": {
     "module": "nodenext",
    "target": "esnext",
    "types": [],

    
    
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,

    
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "moduleResolution": "nodenext",
    "skipLibCheck": true,
  }
}
